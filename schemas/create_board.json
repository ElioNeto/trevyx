{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Create Board",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 100 },
    "description": { "type": "string", "maxLength": 500 },
    "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
  }
}
