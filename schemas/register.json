{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Register",
  "type": "object",
  "required": ["email", "name", "password"],
  "properties": {
    "email": { "type": "string", "format": "email" },
    "name": { "type": "string", "minLength": 1 },
    "password": { "type": "string", "minLength": 6 }
  }
}
